# Railway Bucket (S3-compatible) — copy these from your Railway service's Variables tab
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_ENDPOINT_URL_S3=https://your-bucket-endpoint.railway.app
AWS_REGION=auto
BUCKET_NAME=your_bucket_name

ADMIN_PASSWORD=your_admin_password

EVENT_ID=test

PORT=3000
